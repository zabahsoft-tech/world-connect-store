# Apache / LiteSpeed config for the static SPA build.
# Required so deep links (e.g. /products/foo) and page refreshes don't 404.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for a real file or directory, serve it as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, hand off to the SPA shell so the client router can take over.
  RewriteRule . /index.html [L]
</IfModule>

# Long-cache hashed build assets (filenames include a content hash).
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|mjs|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Never cache the SPA shell — must always pick up new builds.
  <FilesMatch "^(index\.html|sw\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Compression (LiteSpeed honours both blocks; Apache uses mod_deflate).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Common MIME hints (most hosts already know these, included for safety).
<IfModule mod_mime.c>
  AddType application/javascript .mjs
  AddType application/manifest+json .webmanifest
  AddType image/avif .avif
  AddType image/webp .webp
</IfModule>

# Security defaults
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
