# Copy this file to .env on your cPanel host and fill in real values.
# In cPanel's "Setup Node.js App" panel, add each variable individually under
# "Environment variables" — cPanel does NOT auto-load .env files.

# --- Server-side (used by SSR + server functions, never sent to the browser) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Client-side (inlined into the browser bundle at build time) ---
# These MUST be present when you run `npm run build:node`. Re-set them on the
# host only if you intend to rebuild there; otherwise the bundled values win.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# --- Optional ---
# PORT is set automatically by cPanel/Passenger. Override only for local testing.
# PORT=3000
# HOST=0.0.0.0
NODE_ENV=production
